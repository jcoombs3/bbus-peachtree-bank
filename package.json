{
  "name": "bbus-peachtree-bank",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "build": "ng build",
    "e2e": "ng e2e",
    "format": "prettier --write \"{apps,libs}/**/*.ts\"",
    "format:check": "prettier --list-different \"{apps,libs}/**/*.ts\"",
    "lint": "ng lint",
    "ng": "ng",
    "package:apps": "bb-ang build-apps --output-hashing --build-memory=4096",
    "postpackage:apps": "bb-ang create-provisioning-package",
    "package:libs": "bb-ang package-libs",
    "prestart": "bb-ang copy-assets",
    "start": "ng serve",
    "test": "ng test",
    "update": "ng update @bb-cli/schematics@^4 @backbase/foundation-ang@^6",
    "api:check": "bb-ang check-api",
    "api:extract": "bb-ang extract-api",
    "create-experience:retail": "npx sdlc package sdlc/experience.json",
    "bundle-home-page:retail": "sdlc convert-from apps/peachtree-retail-app/sdlc/experience.json apps/peachtree-retail-app/sdlc/pages/home.json -l silent --remove-defaults false -o dist/apps/retail-app/page-model-mock.json"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "~10.1.0",
    "@angular/cdk": "^11.2.0",
    "@angular/common": "~10.1.0",
    "@angular/compiler": "~10.1.0",
    "@angular/core": "~10.1.0",
    "@angular/forms": "~10.1.0",
    "@angular/localize": "~10.1.0",
    "@angular/platform-browser": "~10.1.0",
    "@angular/platform-browser-dynamic": "~10.1.0",
    "@angular/router": "~10.1.0",
    "@backbase/backbase-theme": "latest",
    "@backbase/data-ang": "^3.9.0",
    "@backbase/foundation-ang": "^6.0.0",
    "@backbase/retail-ang": "^3.9.0-sp.2",
    "@backbase/ui-ang": "^5.21.7",
    "@ng-bootstrap/ng-bootstrap": "^9.0.2",
    "@ng-select/ng-select": "^6.1.0",
    "@ngrx/effects": "~10.0.0",
    "@ngrx/store": "~10.0.0",
    "@swimlane/ngx-charts": "^17.0.0",
    "@types/googlemaps": "^3.43.3",
    "core-js": "~2.6.5",
    "rxjs": "~6.6.2",
    "zone.js": "~0.10.3"
  },
  "devDependencies": {
    "@angular-devkit/architect": "~0.1001.0",
    "@angular-devkit/build-angular": "~0.1001.0",
    "@angular/cli": "~10.1.0",
    "@angular/compiler-cli": "~10.1.0",
    "@angular/language-service": "~10.1.0",
    "@backbase/sdlc-convert": "^0.12.23",
    "@bb-cli/bb-ang": "~4.3.0",
    "@bb-cli/schematics": "4.4.2",
    "@types/jasmine": "^3.5.0",
    "@types/jasminewd2": "^2.0.6",
    "@types/node": "^11.11.8",
    "codelyzer": "^6.0.0",
    "jasmine-core": "~3.6.0",
    "jasmine-spec-reporter": "~5.0.0",
    "karma": "~5.0.0",
    "karma-chrome-launcher": "~3.1.0",
    "karma-coverage-istanbul-reporter": "^3.0.2",
    "karma-jasmine": "~4.0.0",
    "karma-jasmine-html-reporter": "^1.5.0",
    "node-sass": "^4.14.1",
    "prettier": "~2.0.5",
    "protractor": "~7.0.0",
    "ts-node": "~8.3.0",
    "tslib": "^2.0.0",
    "tslint": "~6.1.0",
    "typescript": "~4.0.2"
  },
  "engines": {
    "node": "^10.13.0 || ^12.16.1",
    "npm": "^6.11.0"
  },
  "backbase": {
    "defaultScope": "peachtree"
  }
}
